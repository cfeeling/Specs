  },
  "platforms": {
    "ios": "15.0",
    "osx": "12.0",
    "tvos": "15.0"
  },
  "swift_versions": [
    "5.9",
    "5.10"
  ],
  "module_name": "NIS",
  "source_files": [
    "Sources/NIS/**/*.swift"
  ],
