{
  "name": "TFYSwiftSQLiteKit",
  "version": "1.0.1",
  "summary": "Swift ORM layer on SQLite3 with property-wrapper schema and migrations.",
  "description": "TFYSwiftSQLiteKit maps Codable models to SQLite via reflection, supports @TFYPrimaryKey / @TFYColumn /\nindexes / JSON columns, lightweight schema migration (TFYSwiftAutoTable), and WAL-backed connections.",
  "homepage": "https://github.com/13662049573/TFYSwiftSQLite",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "田风有": "420144542@qq.com"
  },
  "source": {
    "git": "https://github.com/13662049573/TFYSwiftSQLite.git",
    "tag": "1.0.1"
  },
  "swift_versions": "5.0",
  "requires_arc": true,
  "module_name": "TFYSwiftSQLiteKit",
  "platforms": {
    "ios": "15.0",
    "osx": "13.5",
    "tvos": "15.0",
    "watchos": "8.0"
  },
  "frameworks": "Foundation",
  "libraries": "sqlite3",
  "source_files": [
    "TFYSwiftSQLite/TFYSwiftSQLiteKit/Annotation/**/*.swift",
    "TFYSwiftSQLite/TFYSwiftSQLiteKit/Core/**/*.swift",
    "TFYSwiftSQLite/TFYSwiftSQLiteKit/Manager/**/*.swift",
    "TFYSwiftSQLite/TFYSwiftSQLiteKit/ORM/**/*.swift",
    "TFYSwiftSQLite/TFYSwiftSQLiteKit/Reflection/**/*.swift",
    "TFYSwiftSQLite/TFYSwiftSQLiteKit/Schema/**/*.swift",
    "TFYSwiftSQLite/TFYSwiftSQLiteKit/Utils/**/*.swift"
  ],
  "swift_version": "5.0"
}
