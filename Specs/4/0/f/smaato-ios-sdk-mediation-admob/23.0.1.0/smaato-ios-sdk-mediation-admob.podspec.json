{
  "name": "smaato-ios-sdk-mediation-admob",
  "version": "23.0.1.0",
  "summary": "Google mobile ads adapter used for mediation with the Smaato SDK",
  "homepage": "https://www.smaato.com/",
  "license": {
    "type": "MIT",
    "file": "LICENSE.txt"
  },
  "authors": {
    "Smaato": "ashwinee.mhaske@smaato.com"
  },
  "platforms": {
    "ios": "12.0"
  },
  "requires_arc": true,
  "source": {
    "git": "https://github.com/vervegroup/ios-sdk-mediation-admob.git",
    "tag": "23.0.1.0"
  },
  "default_subspecs": "Adapters",
  "static_framework": true,
  "xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "i386"
  },
  "dependencies": {
    "Google-Mobile-Ads-SDK": [
      "~> 12.0"
    ]
  },
  "subspecs": [
    {
      "name": "Adapters",
      "dependencies": {
        "smaato-ios-sdk": [
          "23.0.1"
        ],
        "smaato-ios-sdk-mediation-admob/Banner": [

        ],
        "smaato-ios-sdk-mediation-admob/Interstitial": [

        ],
        "smaato-ios-sdk-mediation-admob/RewardedAds": [

        ],
        "smaato-ios-sdk-mediation-admob/Native": [

        ]
      }
    },
    {
      "name": "Banner",
      "dependencies": {
        "smaato-ios-sdk/Banner": [
          "23.0.1"
        ]
      },
      "source_files": "SmaatoSDKAdapters/Banner/*.{h,m}"
    },
    {
      "name": "Interstitial",
      "dependencies": {
        "smaato-ios-sdk/Interstitial": [
          "23.0.1"
        ]
      },
      "source_files": "SmaatoSDKAdapters/Interstitial/*.{h,m}"
    },
    {
      "name": "RewardedAds",
      "dependencies": {
        "smaato-ios-sdk/RewardedAds": [
          "23.0.1"
        ]
      },
      "source_files": "SmaatoSDKAdapters/RewardedVideo/*.{h,m}"
    },
    {
      "name": "Native",
      "dependencies": {
        "smaato-ios-sdk/Native": [
          "23.0.1"
        ]
      },
      "source_files": "SmaatoSDKAdapters/Native/*.{h,m}"
    }
  ]
}
