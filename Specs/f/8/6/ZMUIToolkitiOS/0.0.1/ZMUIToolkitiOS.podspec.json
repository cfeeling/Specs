{
  "name": "ZMUIToolkitiOS",
  "version": "0.0.1",
  "summary": "Zoom Video SDK UI Toolkit for iOS.",
  "description": "Zoom Video SDK UI Toolkit for iOS provides prebuilt UI components and companion binary frameworks that accelerate integration of real-time video collaboration into your app.\n\nBuilt on Zoom Video SDK, the toolkit helps you launch sessions quickly while retaining flexibility for custom experiences.\nIt includes support for core in-session experiences such as audio/video, screen sharing, chat, whiteboard, and related collaboration workflows.\n\nUse the UI Toolkit to reduce implementation time while still leveraging the power and reliability of Zoom Video SDK.",
  "homepage": "https://developers.zoom.us/docs/video-sdk/ios/ui-toolkit/",
  "documentation_url": "https://developers.zoom.us/docs/video-sdk/ios/ui-toolkit/",
  "license": {
    "type": "Commercial",
    "file": "zoom-video-sdk-ui-toolkit-iOS/LICENSE"
  },
  "authors": {
    "Zoom": "https://zoom.us"
  },
  "source": {
    "http": "https://github.com/zoom/videosdk-ui-toolkit-ios/releases/download/beta-0.0.1/zoom-video-sdk-ui-toolkit-iOS.zip",
    "type": "zip"
  },
  "platforms": {
    "ios": "13.0"
  },
  "requires_arc": true,
  "swift_versions": "5.7",
  "pod_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "x86_64"
  },
  "user_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "x86_64"
  },
  "default_subspecs": "ZMUIToolkit",
  "subspecs": [
    {
      "name": "ZoomVideoSDK",
      "vendored_frameworks": "zoom-video-sdk-ui-toolkit-iOS/ZoomVideoSDK.xcframework"
    },
    {
      "name": "zoomcml",
      "vendored_frameworks": "zoom-video-sdk-ui-toolkit-iOS/zoomcml.xcframework"
    },
    {
      "name": "CptShare",
      "vendored_frameworks": "zoom-video-sdk-ui-toolkit-iOS/CptShare.xcframework"
    },
    {
      "name": "Whiteboard",
      "vendored_frameworks": "zoom-video-sdk-ui-toolkit-iOS/Whiteboard.xcframework"
    },
    {
      "name": "ZoomTask",
      "vendored_frameworks": "zoom-video-sdk-ui-toolkit-iOS/ZoomTask.xcframework"
    },
    {
      "name": "zm_annoter_dynamic",
      "vendored_frameworks": "zoom-video-sdk-ui-toolkit-iOS/zm_annoter_dynamic.xcframework"
    },
    {
      "name": "ZMUIToolkit",
      "dependencies": {
        "ZMUIToolkitiOS/ZoomVideoSDK": [

        ],
        "ZMUIToolkitiOS/zoomcml": [

        ],
        "ZMUIToolkitiOS/CptShare": [

        ],
        "ZMUIToolkitiOS/Whiteboard": [

        ],
        "ZMUIToolkitiOS/ZoomTask": [

        ],
        "ZMUIToolkitiOS/zm_annoter_dynamic": [

        ]
      },
      "vendored_frameworks": "zoom-video-sdk-ui-toolkit-iOS/ZMUIToolkit.xcframework"
    },
    {
      "name": "ZoomVideoSDKScreenShare",
      "frameworks": [
        "AVFoundation",
        "CoreGraphics",
        "CoreMedia",
        "CoreVideo",
        "ReplayKit",
        "VideoToolbox"
      ],
      "vendored_frameworks": "zoom-video-sdk-ui-toolkit-iOS/ZoomVideoSDKScreenShare.xcframework"
    }
  ],
  "swift_version": "5.7"
}
