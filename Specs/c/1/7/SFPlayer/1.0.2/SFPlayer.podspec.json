{
  "name": "SFPlayer",
  "version": "1.0.2",
  "summary": "A lightweight custom video player based on AVFoundation.",
  "description": "SFPlayer is a simple and customizable video player component for iOS projects.",
  "homepage": "https://github.com/ChinaKeep/SFPlayer",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "Keep": "keep@example.com"
  },
  "source": {
    "git": "https://github.com/ChinaKeep/SFPlayer.git",
    "tag": "1.0.2"
  },
  "platforms": {
    "ios": "12.0"
  },
  "requires_arc": true,
  "frameworks": [
    "UIKit",
    "AVFoundation"
  ],
  "default_subspecs": [
    "Core",
    "Container"
  ],
  "subspecs": [
    {
      "name": "UI",
      "source_files": [
        "SFPlayer/SFVideoPlayer/SFSlider.{h,m}",
        "SFPlayer/SFVideoPlayer/SFBottonBarView.{h,m}"
      ],
      "public_header_files": [
        "SFPlayer/SFVideoPlayer/SFSlider.h",
        "SFPlayer/SFVideoPlayer/SFBottonBarView.h"
      ]
    },
    {
      "name": "Core",
      "dependencies": {
        "SFPlayer/UI": [

        ]
      },
      "source_files": [
        "SFPlayer/SFVideoPlayer/SFPlayer.{h,m}",
        "SFPlayer/SFVideoPlayer/SFPlayerConfiguration.{h,m}",
        "SFPlayer/SFVideoPlayer/SFPlayerController.{h,m}",
        "SFPlayer/SFVideoPlayer/SFPlayerComponentProtocols.h",
        "SFPlayer/SFVideoPlayer/SFPlayerKit.h"
      ],
      "public_header_files": [
        "SFPlayer/SFVideoPlayer/SFPlayer.h",
        "SFPlayer/SFVideoPlayer/SFPlayerConfiguration.h",
        "SFPlayer/SFVideoPlayer/SFPlayerController.h",
        "SFPlayer/SFVideoPlayer/SFPlayerComponentProtocols.h",
        "SFPlayer/SFVideoPlayer/SFPlayerKit.h"
      ],
      "resources": [
        "SFPlayer/SFVideoPlayer/ImageResources.bundle"
      ]
    },
    {
      "name": "Container",
      "dependencies": {
        "SFPlayer/Core": [

        ],
        "SDWebImage": [
          ">= 5.8"
        ]
      },
      "source_files": [
        "SFPlayer/SFVideoPlayer/SFVideoModel.{h,m}",
        "SFPlayer/SFVideoCell.{h,m}"
      ],
      "public_header_files": [
        "SFPlayer/SFVideoPlayer/SFVideoModel.h",
        "SFPlayer/SFVideoCell.h"
      ]
    }
  ]
}
