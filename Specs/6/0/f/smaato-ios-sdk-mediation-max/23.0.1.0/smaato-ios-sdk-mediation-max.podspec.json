{
  "name": "smaato-ios-sdk-mediation-max",
  "version": "23.0.1.0",
  "summary": "Smaato iOS SDK Custom Network Adapters (Mediation) for AppLovin",
  "homepage": "https://www.smaato.com/",
  "license": {
    "type": "MIT",
    "file": "LICENSE.txt"
  },
  "authors": {
    "Smaato": "ashwinee.mhaske@smaato.com"
  },
  "platforms": {
    "ios": "12.0"
  },
  "requires_arc": true,
  "source": {
    "git": "https://github.com/vervegroup/smaato-ios-sdk-mediation-applovin.git",
    "tag": "23.0.1.0"
  },
  "default_subspecs": "Adapters",
  "static_framework": true,
  "xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "i386"
  },
  "dependencies": {
    "AppLovinSDK": [
      "~> 13.0"
    ]
  },
  "subspecs": [
    {
      "name": "Adapters",
      "dependencies": {
        "smaato-ios-sdk": [
          "23.0.1"
        ]
      },
      "source_files": "SmaatoSDKAdapters/ApplovinWaterfall/*.{h,m}"
    }
  ]
}
