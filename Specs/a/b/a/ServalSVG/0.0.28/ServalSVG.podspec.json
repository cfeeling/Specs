{
  "name": "ServalSVG",
  "version": "0.0.28",
  "summary": "A library for parsing and rendering SVG documents",
  "homepage": "https://github.com/lynx-family/serval-kit",
  "source": {
    "git": "https://github.com/lynx-family/serval-kit.git",
    "commit": "d2dde1e205ccfc523e5c46888766e7673e3a86f2"
  },
  "license": {
    "type": "Apache 2.0"
  },
  "authors": "Lynx",
  "platforms": {
    "ios": "9.0"
  },
  "public_header_files": [
    "svg/include/platform/iOS/SrSVG.h",
    "svg/include/platform/iOS/SrSVGView.h"
  ],
  "source_files": [
    "svg/include/element/**/*.h",
    "svg/include/parser/**/*.h",
    "svg/include/canvas/**/*.h",
    "svg/include/platform/iOS/**/*.h",
    "svg/include/utils/**/*.h",
    "svg/src/element/**/*.{c,cc,cpp}",
    "svg/src/parser/**/*.{c,cc,cpp}",
    "svg/src/utils/**/*.{c,cc,cpp}",
    "svg/platform/iOS/**/*.{mm,m,cc,cpp,c}"
  ],
  "description": "ServalSVG provides an SVG parsing and rendering engine for iOS.\nIt includes DOM parsing, gradient support, shapes, paths and text rendering,\nwith platform-specific canvas implementations and sample projects to help\nintegrate into existing apps.",
  "pod_target_xcconfig": {
    "GCC_PREPROCESSOR_DEFINITIONS": "OS_IOS=1",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++17",
    "CLANG_CXX_LIBRARY": "libc++",
    "CLANG_ENABLE_MODULES": "YES",
    "CLANG_ENABLE_OBJC_ARC": "YES",
    "HEADER_SEARCH_PATHS": "$(inherited) \"$(PODS_TARGET_SRCROOT)/svg/include\"",
    "GCC_C_LANGUAGE_STANDARD": "c11"
  },
  "xcconfig": {
    "OTHER_CPLUSPLUSFLAGS": "-std=c++17 -stdlib=libc++"
  },
  "libraries": [
    "stdc++",
    "c++"
  ]
}
